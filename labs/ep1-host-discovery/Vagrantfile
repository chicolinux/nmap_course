# -*- mode: ruby -*-
# vi: set ft=ruby :

# Episodio 1 — Cartografía: Encontrando Fantasmas en la Red
# Una sola VM en la subred 192.168.56.0/24
# Servicios: SSH (22), HTTP (80), FTP (21)
# El ejercicio consiste en descubrir el host escaneando el rango completo /24

ALPINE_BOX = "generic/alpine319"

Vagrant.configure("2") do |config|
  config.vm.define "target" do |t|
    t.vm.box = ALPINE_BOX
    t.vm.hostname = "safehouse-node"
    t.vm.network "private_network", ip: "192.168.56.10"

    t.vm.provider "virtualbox" do |vb|
      vb.memory = 512
      vb.cpus = 1
      vb.name = "ep1-target"
    end

    t.vm.provision "shell", inline: <<~SHELL
      apk update && apk add --no-cache nginx vsftpd

      # --- FTP (vsftpd) ---
      mkdir -p /var/ftp/pub
      cat > /var/ftp/pub/README.txt << 'TXT'
RED CELL Safehouse — File Repository
Access restricted to authorized personnel.
If you found this, congratulations. You earned your place.
TXT
      cat > /etc/vsftpd/vsftpd.conf << 'FTP'
listen=YES
anonymous_enable=YES
local_enable=NO
write_enable=NO
anon_root=/var/ftp/pub
xferlog_enable=YES
FTP
      rc-update add vsftpd default
      rc-service vsftpd start

      # --- HTTP (nginx) ---
      mkdir -p /var/www/html
      cat > /var/www/html/index.html << 'HTML'
<!DOCTYPE html>
<html>
<head><title>RED CELL — Safehouse Node</title></head>
<body>
  <h1>RED CELL — Safehouse Node</h1>
  <p>Internal network node. Authorized personnel only.</p>
</body>
</html>
HTML
      cat > /etc/nginx/http.d/default.conf << 'NGINX'
server {
    listen 80 default_server;
    server_name _;
    root /var/www/html;
    index index.html;
    location / {
        try_files $uri $uri/ =404;
    }
}
NGINX
      rc-update add nginx default
      rc-service nginx start
    SHELL
  end
end
